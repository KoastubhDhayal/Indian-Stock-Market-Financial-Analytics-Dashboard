# Indian Stock Market Analytics - Environment Variables
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
API_HOST=0.0.0.0
API_PORT=5000
DEBUG=True

# Data Source
DEFAULT_EXCHANGE=NSE
DATA_UPDATE_INTERVAL=5

# Cache Settings
CACHE_ENABLED=True
CACHE_DURATION=60
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Database (Optional)
DATABASE_URL=postgresql://user:password@localhost:5432/stock_analytics

# API Keys (Get these from respective providers)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
NSE_API_KEY=your_nse_api_key_here

# ML Model Configuration
MODEL_UPDATE_FREQUENCY=daily
PREDICTION_HORIZON=1
CONFIDENCE_THRESHOLD=0.65

# Technical Indicators
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD=2

# Alerts
ALERT_ENABLED=True
ALERT_EMAIL=your_email@example.com
ALERT_THRESHOLD_GAIN=5.0
ALERT_THRESHOLD_LOSS=-3.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=stock_analytics.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# WebSocket
WS_ENABLED=True
WS_PORT=8765

# Security
SECRET_KEY=change-this-to-random-secret-key-in-production
JWT_EXPIRY=3600

# Performance
MAX_WORKERS=4
BATCH_SIZE=10

# Feature Flags
ENABLE_ML_PREDICTIONS=True
ENABLE_SENTIMENT_ANALYSIS=False
ENABLE_NEWS_INTEGRATION=False
